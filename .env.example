# ================================================================
# БАЗА ДАННЫХ
# ================================================================
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=product_assistant

# DATABASE_URL внутри Docker — имя сервиса 'db'
# При локальном запуске замените 'db' на 'localhost'
DATABASE_URL=postgresql://postgres:your_secure_password@db:5432/product_assistant

# ================================================================
# AI МОДЕЛЬ
# ================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# Доступные модели: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash
AI_MODEL_NAME=gemini-1.5-flash

# Температура генерации (0.0 — детерминированно, 1.0 — творчески)
AI_TEMPERATURE=0.3

# ================================================================
# TELEGRAM БОТ
# ================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ================================================================
# ПАРСИНГ САЙТА ПРОДУКТОВ
# ================================================================
# Базовый URL раздела с продуктами
PRODUCTS_WEBSITE_URL=https://www.vsk.ru/klientam/avto

# Тип парсера:
#   auto       — автоопределение по структуре сайта (рекомендуется)
#   playwright — SPA / JS-рендеринг (React, Vue, Next.js)
#   requests   — статический HTML
SCRAPER_TYPE=auto

# Явные пути продуктов через запятую (если не задано — берётся из sitemap.xml)
PRODUCT_PATHS=/klientam/avto/kasko,/klientam/avto/kasko-kompakt-minimum,/klientam/avto/osago,/klientam/avto/zelenaya-karta

# ================================================================
# ПРОКСИ (Shadowsocks) — только если Gemini API недоступен напрямую
# Если прокси не нужен — оставьте PROXY_URL пустым или удалите строку.
# Запуск с прокси: docker compose --profile proxy up
# ================================================================
HTTP_PROXY=socks5://ss-client:1080
HTTPS_PROXY=socks5://ss-client:1080
PROXY_URL=socks5://ss-client:1080

SS_ADDRESS=your.shadowsocks.server.com
SS_PORT=9000
SS_PASSWORD=your_shadowsocks_password
